params {

    // Reads and references
    adapter_fa = "/projectnb/bf528/students/ihlee14/final-project-template-ihlee-1014/refs/ATACSeq-SE.fa"
    blacklist = "/projectnb/bf528/students/ihlee14/final-project-template-ihlee-1014/refs/mm10.blacklist.bed"
    genome = "/projectnb/bf528/students/ihlee14/final-project-template-ihlee-1014/refs/genome.fa"
    gtf = "/projectnb/bf528/students/ihlee14/final-project-template-ihlee-1014/refs/genomic.gtf"

    samplesheet = "$projectDir/full_samplesheet.csv"

    window = 2000

    // Directories
    outdir = "$projectDir/results/"
    refdir = "$projectDir/refs/"
}

profiles {
    conda {
        conda.enabled = true
    }
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }
    cluster {
        process {
                executor = 'sge'
                clusterOptions = '-P bf528'
                penv = 'omp'

                withLabel: process_single {
                    cpus = 1
                }

                withLabel: process_low {
                    cpus = 4

                }
                withLabel: process_medium {
                    cpus = 8
                }
                
                withLabel: process_high {
                    cpus = 16
                }
        }
    }

    local {
        process.executor = 'local'
    }
}

executor {
    $sge {
        queueSize = 8
    }
    $local {
        cpus = 1
    }
}

resume = true